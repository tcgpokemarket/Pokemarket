# ──────────────────────────────────────────────
# Supabase (required)
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ──────────────────────────────────────────────
# Stripe (required for payments)
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ──────────────────────────────────────────────
# LiveKit (required for live auctions)
# ──────────────────────────────────────────────
NEXT_PUBLIC_LIVEKIT_URL=wss://your-livekit-server
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# ──────────────────────────────────────────────
# Cloudinary (required for image uploads)
# ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ──────────────────────────────────────────────
# OpenAI (required for AI support assistant)
# ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ──────────────────────────────────────────────
# Pokémon TCG API (required for card data)
# ──────────────────────────────────────────────
POKEMON_TCG_API_KEY=your-pokemon-tcg-api-key
POKEMON_TCG_API_TOKEN=your-pokemon-tcg-api-token

# ──────────────────────────────────────────────
# TCGPlayer (required for price data)
# ──────────────────────────────────────────────
TCGPLAYER_API_KEY=your-tcgplayer-api-key
TCGPLAYER_API_SECRET=your-tcgplayer-api-secret

# ──────────────────────────────────────────────
# eBay (required for cross-listing)
# ──────────────────────────────────────────────
EBAY_APP_ID=your-ebay-app-id

# ──────────────────────────────────────────────
# USPS (required for shipping labels)
# ──────────────────────────────────────────────
USPS_LABELS_URL=https://apis.usps.com/labels/v3/carrier-pickup
USPS_PAYMENT_AUTH_TOKEN=your-usps-payment-auth-token
USPS_PAYMENT_AUTHORIZATION_TOKEN=your-usps-payment-authorization-token

# ──────────────────────────────────────────────
# Admin
# ──────────────────────────────────────────────
# Comma-separated list of admin email addresses
ADMIN_EMAILS=admin@example.com
