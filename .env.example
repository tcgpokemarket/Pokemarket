# =============================================
# TCG Poke Market — Environment Variables
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to git.
# =============================================

# --- Supabase (required) ---
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- Stripe (required for payments) ---
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Get webhook secret from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Site URL (required for Stripe redirects) ---
# In production use your Vercel domain, e.g. https://tcgpokemarket.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- TCGPlayer API (optional — enables live card pricing) ---
# Apply at: https://developer.tcgplayer.com/
TCGPLAYER_API_KEY=
TCGPLAYER_API_SECRET=

# --- eBay Browse API (optional — enables sold price data) ---
# Create app at: https://developer.ebay.com/
EBAY_APP_ID=

# --- PSA API (optional — enables graded card cert lookup) ---
# Apply at: https://www.psacard.com/api
PSA_API_TOKEN=
